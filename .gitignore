# PixelPulse 多模态知识库 .gitignore

# 敏感配置，千万别提交
.env
.env.*
!.env.example
*.env.old
*.env.bak
*.key
*.pem
*.p12
*.pfx
.env.local
.env.*.local
secrets.yaml
credentials.json
private/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.so
*.pyd
.venv/
venv/
env/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
*.pyc
.pip_cache/

# 前端依赖和构建产物
node_modules/
frontend/dist/
frontend/.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
.pnpm-store/

# IDE
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
.atom/

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# 本地数据库数据
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
pgdata/
qdrant_data/
redis_data/

# 日志
logs/
*.log
*.log.*

# 上传文件保留gitkeep
backend/uploads/*
!backend/uploads/.gitkeep
uploads/*
!uploads/.gitkeep

# Docker
.docker/
docker-compose.override.yml
*.dockerignore

# 临时和备份
*.bak
*.backup
*.old
*.orig
*.tmp
*.temp
*.swp
*.swo
*~

# 测试覆盖率
coverage/
.nyc_output/

# 打包文件
*.zip
*.tar.gz
*.rar
*.7z
*.tgz
