# =====================================================================
# PixelPulse — Git Attributes 配置
# 统一跨平台行尾符，避免 Windows/Linux/macOS 换行符冲突
# =====================================================================

# 默认所有文本文件使用 LF 行尾符（Linux/macOS 风格）
* text=auto eol=lf

# Python 文件
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf

# JavaScript/Vue/TypeScript 文件
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# 配置文件
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
.env.* text eol=lf

# 标记语言
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Dockerfile
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Shell 脚本必须使用 LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf

# PowerShell 脚本保持 CRLF（Windows 平台）
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows 批处理保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.svg binary
*.webp binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.pyd binary
*.pyc binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# 锁定文件保持原样
package-lock.json binary
yarn.lock binary
pnpm-lock.yaml binary
poetry.lock binary
Pipfile.lock binary
