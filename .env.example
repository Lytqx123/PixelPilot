# PixelPulse 环境变量配置
# 复制为 .env 后修改

VERSION=2.0.0

# CORS 域名，逗号分隔，开发环境可以留空
# 示例: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pixelpulse
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# JWT密钥，生产一定要改！
SECRET_KEY=pixelpulse-default-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

TEMP_TOKEN_EXPIRE_HOURS=24
APPLICATION_COOLDOWN_DAYS=7
UPLOAD_DIR=./uploads

# Ollama 大模型配置
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=qwen2.5:14b
LLM_NUM_CTX=8192

# 备用大模型，默认关
LLM_LARGE_ENABLED=false
LLM_LARGE_MODEL=qwen2.5:14b
LLM_LARGE_API_URL=http://localhost:11434/api/generate
LLM_LARGE_TEMPERATURE=0.7

# Embedding 模型
EMBEDDING_API_URL=http://localhost:11434/api/embeddings
EMBEDDING_MODEL=bge-m3

# 多模态：图纸/图片理解，不需要就设false
VISION_LLM_API_URL=http://localhost:11434/api/generate
VISION_LLM_MODEL=minicpm-v:8b
VISION_ENABLED=true

# Reranker精排，效果好但慢，机器差可以关
RERANKER_API_URL=http://localhost:11434/api/generate
RERANKER_MODEL=dengcao/Qwen3-Reranker-4B
RERANKER_ENABLED=true
RERANKER_TOP_K=5
RERANKER_PREFETCH=20

# RAG分块参数，一般不用改
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 上传文档去重阈值
DEDUP_SIMILARITY_THRESHOLD=0.98

# 检索相关
RETRIEVAL_TOP_K=7
RETRIEVAL_SIMILARITY_THRESHOLD=0.35
RETRIEVAL_PREFETCH_MULTIPLIER=4
PREVIEW_MAX_SEGMENTS=3
PREVIEW_MAX_CHARS=120

APPLICATION_EXPIRY_DAYS=7
WORKER_CLEANUP_INTERVAL=3600

# 开发环境用，跳过默认密钥检查，生产别设这个
ALLOW_DEFAULT_SECRET=1
